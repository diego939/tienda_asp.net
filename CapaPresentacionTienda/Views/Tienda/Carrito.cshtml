@{
	ViewData["Title"] = "Mi Carrito";
}

<section class="min-vh-80 py-4">
    <div class="container">
        <div class="row">

            <!-- 🛒 LISTA PRODUCTOS -->
            <div class="col-lg-8">
                <div class="card mb-3 border-0 border-bottom">
                    <div class="card-body d-flex justify-content-between">
                        <h4 class="mt-2">Mi carrito</h4>
                        <button class="btn btn-outline-dark bg-gradient rounded-pill" onclick="window.location.href='@Url.Action("Index", "Tienda")'"> <i class="bi bi-cart-plus"></i> Seguir comprando</button>
                    </div>
                </div>
                <div id="contenedorProductos"></div>
            </div>

            <!-- 💰 RESUMEN -->
            <div class="col-lg-4">
                <div class="card shadow-sm rounded-4">
                    <div class="card-body">
                        <h5 class="mb-4">Resumen de Compra</h5>

                        <div class="mb-3">
                            <label>País</label>
                            <select id="cboPais" class="form-select"></select>
                            <div class="invalid-feedback" id="errorPais"></div>
                        </div>

                        <div class="mb-3">
                            <label>Provincia</label>
                            <select id="cboProvincia" class="form-select" disabled></select>
                            <div class="invalid-feedback" id="errorPorvincia"></div>
                        </div>

                        <div class="mb-3">
                            <label>Departamento</label>
                            <select id="cboDepartamento" class="form-select" disabled></select>
                            <div class="invalid-feedback" id="errorDepartamento"></div>
                        </div>

                        <div class="mb-3">
                            <label>Teléfono</label>
                            <input type="text"
                                   id="txtTelefono"
                                   class="form-control"
                                   placeholder="Ej: 11 2345 6789">
                            <div class="invalid-feedback" id="errorTelefono"></div>
                        </div>

                        <div class="mb-3">
                            <label>Dirección</label>
                            <input type="text" id="txtDireccion" class="form-control" placeholder="Calle, número, referencia">
                            <div class="invalid-feedback" id="errorDireccion"></div>
                        </div>

                        <hr />
                        <div class="d-flex justify-content-between mb-3">
                            <strong>Total</strong>
                            <strong>$<span id="totalGeneral">0</span></strong>
                        </div>
                        <div id="paypal-button-container" class="mt-3">
							<!-- Aquí se renderizará el botón de PayPal -->
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<script src="https://www.paypal.com/sdk/js?client-id=AX8faMOFubeVAqiDK_4kG_2gE8Xm7Fi4bLPnjOoHSwzzYejEXvGgzBjuJ-_oHxkavuhjp5YO9iBJKIHM&currency=USD"></script>

@section scripts {
	<script>
         $(document).ready(function () {

            //Llamo a LoadingOverlay una sola vez cuando cargo 
            $("#contenedorProductos").LoadingOverlay("show");
            //Desaparece el LoadingOverlay luego de medio segundo
            setTimeout(function () {
                $("#contenedorProductos").LoadingOverlay("hide");
            }, 500);

            cargarCarrito();
            cargarPais();

            $("#cboPais").change(function () {

                let idPais = $(this).val();

                $("#cboProvincia").prop("disabled", true).html('<option>Seleccione</option>');
                $("#cboDepartamento").prop("disabled", true).html('<option>Seleccione</option>');

                if (idPais) {
                    cargarProvincia(idPais);
                }

                validarFormulario();
            });

            $("#cboProvincia").change(function () {

                let idProvincia = $(this).val();

                $("#cboDepartamento").prop("disabled", true).html('<option>Seleccione</option>');

                if (idProvincia) {
                    cargarDepartamento(idProvincia);
                }

                validarFormulario();
            });

            $("#cboDepartamento, #txtDireccion, #txtTelefono").on("change keyup", function () {
            validarFormulario();
        });

        paypal.Buttons({

            createOrder: function () {

                // validar formulario mostrando error
                if (!validarFormulario(true)) {
                    return Promise.reject();
                }

                let total = parseFloat($("#totalGeneral").text());

                return fetch('@Url.Action("CrearOrdenPaypal", "Tienda")', {
                    method: "POST",
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        total: total
                    })
                })
                .then(res => res.json())
                .then(data => {

                    if (!data.status) {
                        Swal.fire("Error", data.mensaje, "error");
                        throw new Error(data.mensaje);
                    }

                    return data.id;
                });
            },

            onApprove: function (data) {

                return fetch('@Url.Action("CapturarPaypal", "Tienda")', {
                    method: "POST",
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        contacto: '@User.Identity?.Name',
                        telefono: $("#txtTelefono").val(),
                        direccion: $("#txtDireccion").val(),
                        idDepartamento: $("#cboDepartamento").val(),
                        orderId: data.orderID
                    })
                })
                .then(res => res.json())
                .then(response => {

                if (response.status) {

                    Swal.fire({
                        title: "¡Pago realizado!",
                        html: `
                            <p>Tu pago fue procesado correctamente.</p>
                            <strong>ID de transacción:</strong><br>
                            <span style="color:#0d6efd">${response.idTransaccion}</span>
                        `,
                        icon: "success",
                        iconHtml: '<i class="bi bi-bag-check" style="font-size: 3rem; "></i>',
                        showConfirmButton: true,
                        confirmButtonText: "🛒 Ir a la tienda",
                        confirmButtonColor: "#273FF5",      // verde = success
                        allowOutsideClick: false,           // no se cierra al click fuera
                        showCancelButton: false
                    }).then((result) => {
                        if (result.isConfirmed) {
                            // redirige a la tienda
                            window.location.href = '@Url.Action("Index", "Tienda")';
                        }
                    });
            
            // opcional: limpiar carrito
            cargarCarrito();
            actualizarContador(0);

        } else {
            Swal.fire("Error", response.mensaje, "error");
        }

                });
            }

        }).render('#paypal-button-container');

        });

        function cargarPais() {
            $.get('@Url.Action("ListarPais", "Tienda")', function (response) {

                $("#cboPais").html('<option value="">Seleccione</option>');

                $.each(response.data, function (i, item) {
                    $("#cboPais").append(
                        $("<option>").val(item.id).text(item.descripcion)
                    );
                });
            });
        }

        function cargarProvincia(idPais) {

            $("#cboProvincia").html('<option>Cargando...</option>');

            $.post('@Url.Action("ListarProvincia", "Tienda")',
                { idPais: idPais },
                function (response) {

                    $("#cboProvincia").prop("disabled", false);
                    $("#cboProvincia").html('<option value="">Seleccione</option>');

                    $.each(response.data, function (i, item) {
                        $("#cboProvincia").append(
                            $("<option>").val(item.id).text(item.descripcion)
                        );
                    });
                });
        }

        function cargarDepartamento(idProvincia) {

            $("#cboDepartamento").html('<option>Cargando...</option>');

            $.post('@Url.Action("ListarDepartamento", "Tienda")',
                { idProvincia: idProvincia },
                function (response) {

                    $("#cboDepartamento").prop("disabled", false);
                    $("#cboDepartamento").html('<option value="">Seleccione</option>');

                    $.each(response.data, function (i, item) {
                        $("#cboDepartamento").append(
                            $("<option>").val(item.id).text(item.descripcion)
                        );
                    });
                });
        }

        function cargarCarrito(){

            $.ajax({
                url: '@Url.Action("ListarCarrito", "Tienda")',
                type: "GET",
                success: function(response){

                    $("#contenedorProductos").empty();

                    let totalGeneral = 0;


                    if (!response.data || response.data.length === 0) {

                        $("#contenedorProductos").html(`
                            <div class="card p-5 text-center shadow-sm rounded-4 mb-3">
                                <h5>🛒 Tu carrito está vacío</h5>
                                <a class="text-muted text-decoration-none" href="@Url.Action("Index", "Tienda")">Agregá productos para comenzar</a>
                            </div>
                        `);

                        $("#subtotal").text("0.00");
                        $("#totalGeneral").text("0.00");
                        return;
                    }

                    $.each(response.data, function(i, item){

                        totalGeneral += item.total;

                        $("#contenedorProductos").append(`
                            <div class="card mb-3 shadow-sm rounded-4">
                                <div class="card-body">
                                    <div class="row align-items-center">

                                        <!-- Imagen -->
                                        <div class="col-md-2 col-4">
                                            <img src="${item.imagen}"
                                                 class="img-fluid rounded"
                                                 alt="${item.producto}">
                                        </div>

                                        <!-- Info -->
                                        <div class="col-md-3 col-8">
                                            <h6 class="mb-1">${item.producto}</h6>
                                            <small class="text-muted">Precio unitario</small>
                                            <div>$${item.precio}</div>
                                        </div>

                                        <!-- Cantidad -->
                                        <div class="col-md-3 col-12 mt-3 mt-md-0">
                                            <div class="input-group mx-auto" style="max-width: 120px;">

                                                <button class="btn btn-outline-dark"
                                                    onclick="modificarCantidad(${item.idProducto}, -1, this)"
                                                     ${item.cantidad === 1 ? 'disabled' : ''}>
                                                    -
                                                </button>

                                                <input type="text"
                                                       class="form-control text-center"
                                                       value="${item.cantidad}"
                                                       readonly>

                                                <button class="btn btn-outline-dark"
                                                    onclick="modificarCantidad(${item.idProducto}, 1, this)">
                                                    +
                                                </button>

                                            </div>
                                        </div>

                                        <!-- Total -->
                                        <div class="col-md-2 col-6 mt-3 mt-md-0 text-md-center">
                                            <small class="text-muted">Subtotal</small>
                                            <div>
                                                <strong>$${item.total}</strong>
                                            </div>
                                        </div>

                                        <!-- Eliminar -->
                                        <div class="col-md-2 col-6 mt-3 mt-md-0 text-end">
                                            <button class="btn btn-outline-danger rounded-circle"
                                                    onclick="eliminar(${item.id})">
                                                <i class="fa-solid fa-x"></i>
                                            </button>
                                        </div>

                                    </div>
                                </div>
                            </div>
                        `);
                    });

                    $("#subtotal").text(totalGeneral.toFixed(2));
                    $("#totalGeneral").text(totalGeneral.toFixed(2));
                }
            });
        }

        function modificarCantidad(idProducto, cambio, btn){

            if(!idProducto) return;

            let contenedor = $(btn).closest(".input-group");

            // 🔒 Deshabilitar ambos botones
            contenedor.find("button").prop("disabled", true);

            // ⏳ Mostrar loading sobre el input-group
            contenedor.LoadingOverlay("show");

            agregarCarrito(idProducto, cambio);

            // Esperamos que termine el ajax y luego recargamos carrito
            setTimeout(function(){
                cargarCarrito();
            }, 300);
        }

        function agregarCarrito(idProducto,cantidad){

            $.ajax({
                url: '@Url.Action("AgregarCarrito", "Tienda")',
                type: "POST",
                data: {
                    idProducto: idProducto,
                    cantidad: cantidad
                },
                success: function(response){
                    if(response.respuesta){

                        actualizarContador(response.cantidad);

                        Swal.fire({
                            toast: true,
                            position: 'top',
                            icon: 'success',
                            title: 'Cantidad actualizada',
                            showConfirmButton: false,
                            timer: 2000,
                            timerProgressBar: true
                        });

                    }else{

                        Swal.fire({
                            toast: true,
                            position: 'top',
                            icon: 'error',
                            title: response.mensaje,
                            showConfirmButton: false,
                            timer: 2000,
                            timerProgressBar: true
                        });

                    }
                }
            });
        }

		function eliminar(idCarrito){

			$.ajax({
				url: '@Url.Action("EliminarCarrito", "Tienda")',
				type: "POST",
				data: { idCarrito: idCarrito },
				success: function(response){
					if(response.respuesta){
						actualizarContador(response.cantidad);
                        mostrarToast("success", "Producto quitado");
						cargarCarrito();
					}else{
                        mostrarToast("error", response.mensaje);
					}
				}
			});
		}

        function validarFormulario(mostrarError = false) {

            let pais = $("#cboPais");
            let provincia = $("#cboProvincia");
            let departamento = $("#cboDepartamento");
            let direccion = $("#txtDireccion");
            let telefono = $("#txtTelefono");

            let total = parseFloat($("#totalGeneral").text());

            let telefonoValido = /^[0-9+\-\s()]{6,20}$/.test(telefono.val().trim());

            let valido = true;
            let mensaje = "";

            $(".is-invalid").removeClass("is-invalid");
            $(".invalid-feedback").text("");

            // única alerta
            if (total <= 0) {
                if (mostrarError) {
                            Swal.fire({
                                icon: "warning",
                                iconHtml: '<i class="bi bi-cart-x" style="font-size: 3rem;"></i>',
                                title: "Carrito vacío",
                                text: "Agregue productos antes de pagar",
                                confirmButtonText: "🛒 Ver productos",
                                showCancelButton: true,
                                cancelButtonText: "Cancelar",
                                confirmButtonColor: "#dc3545",   // rojo = danger
                                cancelButtonColor: "#198754"     // verde = success
                            }).then((result) => {
                                if (result.isConfirmed) {
                                    window.location.href = '@Url.Action("Index", "Tienda")';
                                }
                            });
                }
                return false;
            }

            if (!pais.val()) {
                mensaje = "Debe seleccionar un país";
                pais.addClass("is-invalid");
                $("#errorPais").text(mensaje);
                valido = false;
            }

            if (!provincia.val()) {
                mensaje = "Debe seleccionar una provincia";
                provincia.addClass("is-invalid");
                $("#errorProvincia").text(mensaje);
                valido = false;
            }

            if (!departamento.val()) {
                mensaje = "Debe seleccionar un departamento";
                departamento.addClass("is-invalid");
                $("#errorDepartamento").text(mensaje);
                valido = false;
            }

            if (!telefonoValido) {
                mensaje = "Ingrese un teléfono válido";
                telefono.addClass("is-invalid");
                $("#errorTelefono").text(mensaje);
                valido = false;
            }

            if (!direccion.val().trim()) {
                mensaje = "Debe ingresar la dirección";
                direccion.addClass("is-invalid");
                $("#errorDireccion").text(mensaje);
                valido = false;
            }

            return valido;
        }
	</script>
}