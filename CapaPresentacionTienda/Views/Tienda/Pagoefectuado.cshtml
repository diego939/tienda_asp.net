@{
	ViewData["Title"] = "Pago Efectuado";
}
<div class="container py-5 text-center">

    @if ((bool)ViewData["Status"])
    {
        <div class="card shadow p-5">
            <h1 class="text-success">¡Gracias por tu compra!</h1>
            <h5 class="mt-3">ID Transacción:</h5>
            <strong>@ViewData["id_transaccion"]</strong>

            <div class="mt-4">
                <a class="btn btn-primary"
                   href="@Url.Action("Index", "Tienda")">
                    Volver a la tienda
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow p-5">
            <h1 class="text-danger">Pago no realizado</h1>
            <p>Hubo un problema procesando tu compra.</p>

            <a class="btn btn-secondary"
               href="@Url.Action("Index", "Tienda")">
                Volver a la tienda
            </a>
        </div>
    }

</div>