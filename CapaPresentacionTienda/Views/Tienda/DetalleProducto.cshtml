@model CapaEntidad.Producto

@{
    ViewData["Title"] = "Detalle del Producto";
}

<section class="py-5">
    <div class="container px-4 px-lg-5 my-5">

        @if (Model != null)
        {
            <div class="row gx-4 gx-lg-5 align-items-center">

                <!-- Imagen -->
                <div class="col-md-6 text-center">
                    @{
                        string imagen = !string.IsNullOrEmpty(Model.base64)
                        ? $"data:image/{Model.extension.Replace(".", "")};base64,{Model.base64}"
                        : "https://dummyimage.com/600x700/dee2e6/6c757d.jpg";
                    }

                    <img class="card-img-top mb-5 mb-md-0 img-fluid rounded shadow"
                         src="@imagen"
                         alt="@Model.nombre" />
                </div>

                <!-- Información -->
                <div class="col-md-6">

                    <div class="small mb-1 text-muted">
                        Categoría: @Model.oCategoria?.descripcion
                    </div>

                    <div class="small mb-3 text-muted">
                        Marca: @Model.oMarca?.descripcion
                    </div>

                    <h1 class="display-5 fw-bolder">
                        @Model.nombre
                    </h1>

                    <div class="fs-4 mb-4 text-success fw-bold">
                        $@Model.precio
                    </div>

                    <p class="lead">
                        @Model.descripcion
                    </p>

                    <div class="mb-3">
                        <span class="badge bg-dark">
                            Stock disponible: @Model.stock
                        </span>
                    </div>

                    <div class="d-flex gap-3">

                        <div class="input-group" style="max-width: 100px;">

                            <button class="btn btn-outline-dark"
                                    type="button"
                                    onclick="cambiarCantidad(-1)">
                                -
                            </button>

                            <input type="text"
                                   id="inputQuantity"
                                   class="form-control text-center"
                                   value="1"
                                   readonly />

                            <button class="btn btn-outline-dark"
                                    type="button"
                                    onclick="cambiarCantidad(1)">
                                +
                            </button>

                        </div>

                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <button class="btn btn-outline-dark flex-shrink-0" onclick="agregarDetalle(@Model.id)">
                                <i class="bi-cart-fill me-1"></i>
                                Agregar al carrito
                            </button>
                        }
                        else
                        {
                            <a href="@Url.Action("Index", "Acceso")" class="btn">
                                Iniciar sesión para comprar
                            </a>
                        }

                    </div>

                    <div class="mt-4">
                        <a href="@Url.Action("Index", "Tienda")" class="btn btn-outline-danger">
                            ← Volver a la tienda
                        </a>
                    </div>

                </div>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <h3 class="text-danger">Producto no encontrado</h3>
                <a href="@Url.Action("Index", "Tienda")" class="btn btn-outline-danger mt-3">
                    Volver a la tienda
                </a>
            </div>
        }

    </div>
</section>

@section scripts{
    <script>
        function agregarDetalle(idProducto){

            let cantidad = $("#inputQuantity").val();

            $.ajax({
                url: '@Url.Action("AgregarCarrito", "Tienda")',
                type: "POST",
                data: {
                    idProducto: idProducto,
                    cantidad: cantidad
                },
                success: function(response){
                    if(response.respuesta){
                        actualizarContador(response.cantidad);
                        mostrarToast('success', 'Producto agregado');
                    }else{
                        mostrarToast('error', response.mensaje);
                    }
                }
            });
        }

        function cambiarCantidad(cambio){

            let input = $("#inputQuantity");
            let cantidadActual = parseInt(input.val());
            let stock = @Model.stock;

            let nuevaCantidad = cantidadActual + cambio;

            // 🚫 No menor a 1
            if(nuevaCantidad < 1){
                Swal.fire({
                    toast: true,
                    position: 'top',
                    icon: 'warning',
                    title: 'La cantidad mínima es 1',
                    showConfirmButton: false,
                    timer: 2000,
                    timerProgressBar: true
                });
                return;
            }

            // 🚫 No mayor al stock
            if(nuevaCantidad > stock){
                Swal.fire({
                    toast: true,
                    position: 'top',
                    icon: 'warning',
                    title: 'Stock máximo alcanzado',
                    showConfirmButton: false,
                    timer: 2000,
                    timerProgressBar: true
                });
                return;
            }

            input.val(nuevaCantidad);
        }
    </script>
}