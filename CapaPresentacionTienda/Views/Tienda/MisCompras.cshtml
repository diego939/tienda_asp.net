@{
    ViewData["Title"] = "Mis Compras";
}

<div class="container mt-4" id="comprasApp">

    <h4 class="mb-3">Mis Compras</h4>

    <!-- BUSCADOR Y ORDEN -->
    <div class="row g-2 mb-3 align-items-center">

        <!-- BUSCADOR -->
        <div class="col-12 col-md-6">

            <div class="position-relative">

                <i class="bi bi-search
           position-absolute
           top-50
           start-0
           translate-middle-y
           ms-3
           text-secondary"></i>

                <input class="search form-control ps-5 rounded-pill shadow-sm"
                       type="search"
                       placeholder="Buscar transacción...">

            </div>

        </div>

        <!-- ORDEN FECHA -->
        <div class="col-12 col-md-3">
            <button class="sort btn btn-outline-warning w-100 rounded-pill shadow-sm"
                    data-sort="fecha">
                <i class="bi bi-calendar me-1"></i>
                Ordenar por fecha
                <span class="icono-orden ms-1"></span>
            </button>
        </div>

        <!-- ORDEN PRECIO -->
        <div class="col-12 col-md-3">
            <button class="sort btn btn-outline-success w-100 rounded-pill shadow-sm"
                    data-sort="precio">
                <i class="bi bi-cash-coin me-1"></i>
                Ordenar por precio
                <span class="icono-orden ms-1"></span>
            </button>
        </div>

    </div>

    <hr>

    <!-- CARDS -->
    <div class="row list" id="contenedorCompras"></div>

    <!-- PAGINACION -->
    <ul class="pagination justify-content-center mt-4"></ul>

</div>

<!-- Modal detalle -->
<div class="modal fade" id="modalDetalle">

    <div class="modal-dialog modal-md">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="fw-bold" id="idVenta"></h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <div class="d-flex justify-content-between">
                    <div class="fw-semibold">Transacción:</div>
                    <div class="text-secondary" id="transaccionVenta"></div>
                </div>

                <div class="d-flex justify-content-between">
                    <div class="fw-semibold">Fecha:</div>
                    <div class="text-secondary" id="fechaVenta"></div>
                </div>

                <div class="mt-4 border-bottom pb-2 fw-bold d-flex">
                    <div style="flex:2">Producto</div>
                    <div style="flex:1">Cantidad</div>
                    <div style="flex:1">Total</div>
                </div>

                <div id="tablaDetalle"></div>

            </div>

            <div class="modal-footer d-flex justify-content-between">
                <span class="fw-bold">Total</span>
                <span class="fw-bold text-success">$ <span id="totalVenta"></span></span>
            </div>

        </div>
    </div>

</div>
@section scripts {

    <script src="https://cdnjs.cloudflare.com/ajax/libs/list.js/2.3.1/list.min.js"></script>

    <script>

        document.querySelectorAll(".sort").forEach(btn => {

            btn.addEventListener("click", function () {

                let icono = this.querySelector(".icono-orden");

                // resetear iconos de otros botones
                document.querySelectorAll(".icono-orden").forEach(i => {
                    if (i !== icono) i.innerHTML = "";
                });

                // alternar icono
                if (icono.innerHTML === "↑") {
                    icono.innerHTML = "↓";
                } else {
                    icono.innerHTML = "↑";
                }

            });

        });

        let listaCompras;

        $.get("/Tienda/ListarMisCompras", function (response) {

            let html = "";

            response.data.forEach(function (venta) {

                let fechaObj = new Date(venta.fecha_registro);

                let fecha = fechaObj.toLocaleString('es-AR', {
                    day: '2-digit',
                    month: '2-digit',
                    year: 'numeric',
                    hour: '2-digit',
                    minute: '2-digit',
                    hour12: false
                });

                html += `

                <div class="col-md-3 mb-3 list-item">

                    <div class="card shadow-sm h-100 border-secondary">

                        <div class="card-body d-flex flex-column">

                            <h6 class="fw-bold">
                                Venta #${venta.id}
                            </h6>

                            <p class="mb-1">
                                <b>Transacción: </b>
                                <span class="nombre text-secondary">
                                    ${venta.id_transaccion}
                                </span>
                            </p>

                            <p class="mb-1">
                                <b>Productos:</b> ${venta.total_productos}
                            </p>

                            <p class="fecha mb-1">
                                <b>Fecha:</b> ${fecha}
                            </p>

                            <p class="fw-bold text-success precio">
                                <span class="text-dark">Total:</span> $ ${venta.monto_total}
                            </p>

                            <button class="btn btn-outline-dark btn-sm mt-auto verDetalle"
                                data-id="${venta.id}"
                                data-transaccion="${venta.id_transaccion}"
                                data-total="${venta.monto_total}"
                                data-fecha="${fecha}">
                                <i class="bi bi-eye"></i> Detalle
                            </button>

                        </div>

                    </div>

                </div>
                `;

            });

            $("#contenedorCompras").html(html);

            listaCompras = new List('comprasApp', {
                valueNames: ['nombre','fecha','precio'],
                page: 8,
                pagination: true
            });

        });


        // ABRIR DETALLE
        $("#contenedorCompras").on("click", ".verDetalle", function () {

            let idVenta = $(this).data("id");
            let transaccion = $(this).data("transaccion");
            let total = $(this).data("total");
            let fecha = $(this).data("fecha");

            $("#idVenta").text("N° de venta: #" + idVenta);
            $("#transaccionVenta").text(transaccion);
            $("#modalDetalle #totalVenta").text(total);
            $("#fechaVenta").text(fecha);

            $.get("/Tienda/ObtenerDetalleVenta?idVenta=" + idVenta, function (response) {

                $("#tablaDetalle").html("");

                response.data.forEach(function (item) {

                    $("#tablaDetalle").append(`
                        <div class="d-flex border-bottom py-2 text-secondary">
                            <div style="flex:2">${item.oProducto.nombre}</div>
                            <div style="flex:1">x ${item.cantidad}</div>
                            <div style="flex:1">$ ${item.total}</div>
                        </div>
                    `);

                });

                new bootstrap.Modal(document.getElementById("modalDetalle")).show();

            });

        });

    </script>
}

<style>
    .pagination li {
        list-style: none;
        margin: 0 4px;
    }

        .pagination li a {
            display: inline-block;
            padding: 6px 14px;
            border: 1px solid #212529;
            color: #212529;
            text-decoration: none;
            border-radius: 999px; /* rounded-pill */
            transition: all .2s ease;
        }

            /* estilo btn-outline-dark */
            .pagination li a:hover {
                background-color: #212529;
                color: white;
            }

        /* active = btn-dark */
        .pagination li.active a {
            background-color: #212529;
            color: white;
            border-color: #212529;
        }
</style>